# ============================================================
# TextCraft 环境服务器 Docker 镜像
# 职责：运行 textcraft 游戏服务器，接受训练容器的请求
# 无 GPU 需求，轻量 Python 3.11 镜像
# ============================================================

FROM python:3.11-slim

LABEL maintainer="wyh"
LABEL description="TextCraft Environment Server for RL Training"

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# 安装 textcraft 核心依赖
RUN pip install --no-cache-dir \
    fastapi==0.121.2 \
    uvicorn==0.38.0 \
    gymnasium==1.1.1 \
    transformers==4.57.1 \
    numpy==2.0.2

# 从 GitHub 安装 agentenv-textcraft
# 对应本地路径：/Data/wyh/AgentGym-RL/AgentGym/agentenv-textcraft
RUN pip install --no-cache-dir \
    "git+https://github.com/WooooDyy/AgentGym.git#subdirectory=agentenv-textcraft"

# 健康检查
HEALTHCHECK --interval=10s --timeout=5s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:${TEXTCRAFT_PORT:-36001}/ | grep -q "TextCraft" || exit 1

EXPOSE 36001

ENV TEXTCRAFT_HOST=0.0.0.0
ENV TEXTCRAFT_PORT=36001

CMD ["sh", "-c", "textcraft --host ${TEXTCRAFT_HOST} --port ${TEXTCRAFT_PORT}"]
