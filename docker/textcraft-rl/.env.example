# ============================================================
# TextCraft RL 环境变量模板
# 使用方法：
#   cp .env.example .env
#   vim .env  # 按实际路径修改
#   docker-compose up -d
# ============================================================

# ── 路径配置（必填，按实际服务器路径修改）──────────────────
# verl 代码仓库路径
VERL_CODE_DIR=/Data/wyh/verl

# 数据集路径（包含训练/验证 parquet 文件）
DATASETS_DIR=/Data/wyh/datasets

# 模型存放路径（Qwen3-0.6B / 1.7B / 4B / 8B 等）
MODELS_DIR=/Data/public

# 训练输出路径（checkpoints、logs、wandb 等）
OUTPUTS_DIR=/Data/wyh/datasets/Verl-Data/outputs

# HuggingFace 模型缓存路径
HF_CACHE_DIR=/Data/cache/huggingface

# ── API 密钥（可选）────────────────────────────────────────
WANDB_API_KEY=
HF_TOKEN=

# ── TextCraft 服务器配置 ────────────────────────────────────
TEXTCRAFT_PORT=36001
# host 网络模式下，训练容器通过 localhost 访问游戏服务器
TEXTCRAFT_SERVER_URL=http://127.0.0.1:36001

# ── GPU 配置 ────────────────────────────────────────────────
# 留空表示使用所有 GPU，指定则限制（如 "0,1,2,3"）
CUDA_VISIBLE_DEVICES=

# ── 实验配置（可选，也可在 run_training.sh 调用时传入）─────
# 实验类型：grpo_baseline | prefix_full | prefix_guided | prefix_guided_dr | sft
EXPERIMENT=grpo_baseline

# 模型目录名（在 MODELS_DIR 下的子目录）
MODEL_NAME=Qwen3-1.7B

# 训练轮数
NUM_EPOCHS=100

# ── 调试配置（可选）────────────────────────────────────────
NCCL_DEBUG=WARN
